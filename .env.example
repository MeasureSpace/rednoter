# Whisper model to use for transcription (default: large-v2 via MLX, ~3GB download on first run)
# Options: mlx-community/whisper-large-v2-mlx, mlx-community/whisper-small-mlx, etc.
REDNOTER_WHISPER_MODEL=mlx-community/whisper-large-v2-mlx

# How many days to keep downloaded audio files before auto-deleting (default: 5)
REDNOTER_AUDIO_RETENTION_DAYS=5
